name: Deploy to Hugging Face Spaces

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  deploy:
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    runs-on: ubuntu-latest
    
    steps:
    - uses: actions/checkout@v4
      with:
        fetch-depth: 0
        lfs: true
    
    - name: Set up Python 3.10
      uses: actions/setup-python@v4
      with:
        python-version: '3.10'
    
    - name: Install Poetry
      uses: snok/install-poetry@v1
      with:
        version: latest
        virtualenvs-create: true
        virtualenvs-in-project: true
    
    - name: Install dependencies
      run: |
        poetry install
    
    - name: Run quality checks
      run: |
        poetry run ruff check src/
        poetry run ruff format --check src/
        poetry run python -m py_compile src/app.py
    
    - name: Export requirements.txt
      run: |
        poetry export --format requirements.txt --output requirements.txt --without-hashes
    
    - name: Push to Hugging Face Spaces
      env:
        HF_TOKEN: ${{ secrets.HF_TOKEN }}
      run: |
        git config --global user.email "action@github.com"
        git config --global user.name "GitHub Action"
        
        # Clone your HF Space repo
        git clone https://huggingface.co/spaces/tbowman01/granite-docling-258m-demo hf-space
        
        # Copy files (excluding .git and other unwanted files)
        rsync -av --exclude='.git' --exclude='hf-space' --exclude='.env' . hf-space/
        
        cd hf-space
        
        # Configure git with HF token
        git remote set-url origin https://tbowman01:$HF_TOKEN@huggingface.co/spaces/tbowman01/granite-docling-258m-demo
        
        # Commit and push changes
        git add .
        git commit -m "Auto-deploy from GitHub: ${{ github.sha }}" || exit 0
        git push origin main

  test:
    runs-on: ubuntu-latest
    
    steps:
    - uses: actions/checkout@v4
    
    - name: Set up Python 3.10
      uses: actions/setup-python@v4
      with:
        python-version: '3.10'
    
    - name: Install Poetry
      uses: snok/install-poetry@v1
      with:
        version: latest
        virtualenvs-create: true
        virtualenvs-in-project: true
    
    - name: Install dependencies
      run: |
        poetry install
    
    - name: Run comprehensive tests
      run: |
        # Run the same checks as make test-all
        poetry run ruff check src/
        poetry run ruff format --check src/
        poetry run python -m py_compile src/app.py
        find src/ -name "*.py" -exec python -m py_compile {} \;
        
        # Test imports (with NO_LLM to avoid model loading)
        NO_LLM=1 poetry run python -c "import src.app; print('✅ All imports successful!')"
